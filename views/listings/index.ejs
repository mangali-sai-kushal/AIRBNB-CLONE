<% layout('layouts/boilerplate') -%>
<%= success %>
<%= error %>
<style>
  .filters-wrapper {
    width: 100%;
  padding: 0 3rem;
  display: flex;
  flex: nowrap;
  
}

/* Scroll container */
#filters {
  width: 100%;
  display: flex;
  gap: 2rem;
  overflow-x: auto;
  scroll-behavior: smooth;
  scrollbar-width: none;
  align-items: center; /* Firefox */
}

#filters::-webkit-scrollbar {
  display: none; /* Chrome */
}

.filter {
  margin-top: 2rem;
  min-width: 79px;
  text-align: center;
  cursor: pointer;
  opacity: 0.7;
  white-space: nowrap;
}

.filter i {
  font-size: 1.4rem;
}

.filter p {
  font-size: 0.8rem;
  margin: 0;
}

.filter:hover,
.filter.active {
  opacity: 1;
}
.taxToggle {
  position: relative;
  top: 10px;
  right: 20px;
}
/* Scroll Buttons */
.scroll-btn {
  margin-top: 2rem;;
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: white;
  border: 1px solid #ddd;
  border-radius: 50%;
  width: 40px;
  height: 40px;
  z-index: 10;
  opacity: 0.8;
}

.scroll-btn:hover {
  opacity: 1;
}

.scroll-btn.left {
  left: 5px;
  top: 10px;
}

.scroll-btn.right {
  right: 12rem;
  top: 10px;
}

/* Mobile behavior */
@media (max-width: 576px) {
  .scroll-btn {
    display: none;
  }
}
.tax-toggle {
  margin-left: 11rem;
  border: 1px solid black;
  padding: 5px 10px;
  border-radius: 12px;
  right: 2px;
  height: 3.5rem;
  display: flex;
  align-items: center;

}


</style>  

  <div class="filters-wrapper position-relative d-flex align-items-center">

  <!-- Left Arrow -->
  <button class="scroll-btn left" onclick="scrollFilters(-250)">
    <i class="fa-solid fa-chevron-left"></i>
  </button>

  <!-- Scrollable Filters -->
  <div id="filters">

    <div class="filter">
      <i class="fa-solid fa-fire"></i>
      <p>Trending</p>
    </div>

    <div class="filter">
      <i class="fa-solid fa-bed"></i>
      <p>Nightlife</p>
    </div>

    <div class="filter">
      <i class="fa-solid fa-mountain"></i>
      <p>Outdoors</p>
    </div>

    <div class="filter">
      <i class="fa-solid fa-city"></i>
      <p>City</p>
    </div>

    <div class="filter">
      <i class="fa-solid fa-tree"></i>
      <p>Nature</p>
    </div>

    <div class="filter">
      <i class="fa-solid fa-umbrella-beach"></i>
      <p>Beach</p>
    </div>

    <div class="filter">
      <i class="fa-solid fa-landmark"></i>
      <p>Historic</p>
    </div>

    <div class="filter">
      <i class="fa-brands fa-fort-awesome"></i>
      <p>Castles</p>
    </div>

    <div class="filter">
      <i class="fa-solid fa-skiing-nordic"></i>
      <p>Skiing</p>
    </div>

    <div class="filter">
      <i class="fa-solid fa-person-swimming"></i>
      <p>Swimming</p>
    </div>

    <div class="filter">
      <i class="fa-solid fa-hotel"></i>
      <p>Resorts</p>
    </div>

    <div class="filter">
      <i class="fa-solid fa-campground"></i>
      <p>Camps</p>
    </div>

    <div class="filter">
      <i class="fa-solid fa-snowflake"></i>
      <p>Cool places</p>
    </div>

    <div class="filter">
      <i class="fa-solid fa-tree-city"></i>
      <p>Cabins</p>
    </div>

  </div>

  <!-- Right Arrow -->
  <button class="scroll-btn right" onclick="scrollFilters(250)">
    <i class="fa-solid fa-chevron-right"></i>
  </button>
  
  <div class="tax-toggle ms-4">
    <div class="form-check form-switch">
      <label class="form-check-label" for="switchCheckDefault">Display Taxes</label>
  <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
  
</div>
  </div>

</div>

   
  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4 mt-3">
 <% for(let listing of allListings){ %>
<a href="/listings/<%= listing._id %>" class="listing-link"">

  <div class="card col listing-card" style="width: 20rem;">
  <img src="<%= listing.image.url %>" class="card-img-top" 
  alt="listing_image" 
  style="height: 20rem;">
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text">
      <b><%= listing.title %></b>
      <br>
      &#8377; <%= listing.price.toLocaleString("en-IN") %>/night
      <i class="tax-info"> &nbsp; &nbsp+18% GST</i>
    </p>
  </div>
  
</div>
</a>
<% } %>
  </div>


<script>
  const filters = document.getElementById("filters");

  function scrollFilters(value) {
    filters.scrollBy({
      left: value,
      behavior: "smooth"
    });
  }

  // Active state
  document.querySelectorAll('.filter').forEach(f => {
    f.addEventListener('click', () => {
      document.querySelectorAll('.filter').forEach(el =>
        el.classList.remove('active')
      );
      f.classList.add('active');
    });
  });

  const taxSwitch = document.getElementById('switchCheckDefault');
  taxSwitch.addEventListener('change', () => {
    let taxInfo=document.querySelectorAll('.tax-info');
    if(taxSwitch.checked){
      taxInfo.forEach(info => {
        info.style.display = 'inline';
      });
    } else {
      taxInfo.forEach(info => {
        info.style.display = 'none';
      });
    }

    
  });
</script>



